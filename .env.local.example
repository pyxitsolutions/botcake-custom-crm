NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Botcake / webhook API (primary lead source)
LEADS_API_SECRET=your_random_secret

# Google Sheets (disabled by default — set to true to re-enable)
GOOGLE_SHEETS_SYNC_ENABLED=false

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_RANGE=Sheet1!A:J

# Optional: protect automated sync endpoint
CRON_SECRET=your_random_secret
